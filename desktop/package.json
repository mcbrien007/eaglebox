{
  "name": "eaglebox-desktop",
  "version": "1.0.0",
  "description": "EagleBox desktop application",
  "author": "EagleBox",
  "main": "src/main.js",
  "type": "module",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.eaglebox.desktop",
    "productName": "EagleBox",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "renderer/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": "portable",
      "signingHashAlgorithms": null
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.0.0",
    "electron-packager": "^17.1.2"
  },
  "dependencies": {
    "b4a": "^1.6.6",
    "hyperswarm": "^4.7.0",
    "sodium-native": "^4.1.0"
  }
}
